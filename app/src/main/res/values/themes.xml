<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. UI itself is rendered entirely with Jetpack Compose
         Material3; this XML theme only controls the window before Compose takes over. -->
    <style name="Theme.FileManager" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
